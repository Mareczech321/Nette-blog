services:
	- App\Router\RouterFactory::createRouter
	- App\Model\PostFacade
	security.authenticator: App\Model\Auth\Authenticator
	- App\Components\ICommentFormFactory
	- App\Components\ILoginFormFactory
	- App\Components\ISignUpFormFactory
	- App\Components\ICreateFormFactory
	- App\Components\IEditCommentFormFactory
	- App\Model\CommentFacade
	- App\Components\IEditPostFormFactory
	- App\Model\PremiumService
	- App\Model\FeedManager
	- App\Model\ChartManager
	- App\Model\Mapper\PostMapper
	- App\Model\Mapper\CommentMapper
	- App\Model\Mapper\PostFormMapper
	- App\Model\Mapper\CommentFormMapper
	- App\Model\ImageManager(%wwwDir%/assets/img)
	- App\Model\Mapper\PostUrlMapper
	- App\Model\Repository\PremiumPlanRepository
	- App\Model\PremiumFacade
	- App\Model\OrderFacade
	- App\Model\Session\CartSession
	- App\Model\Mapper\OrderMapper
	- App\Components\IProfileEditFormFactory
	- App\Components\IChangePasswordFormFactory
