	messageRepository: App\Model\Repository\MessageRepository(@database.default.explorer, @App\Model\Service\EncryptionService, 'c2VjcmV0QXBwRW5jb2RlS2V5')
	messageFacade: App\Model\MessageFacade(@messageRepository, @App\Model\Service\EncryptionService, 'c2VjcmV0QXBwRW5jb2RlS2V5')
